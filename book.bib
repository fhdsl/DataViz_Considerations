@article{Xing_etal_2025,
  title={Pan-cancer human brain metastases atlas at single-cell resolution},
  volume={43},
  ISSN={1535-6108},
  url={https://www.sciencedirect.com/science/article/pii/S1535610825001266},
  DOI={10.1016/j.ccell.2025.03.025},
  abstractNote={Brain metastases (BrMs) remain a major clinical and therapeutic challenge in patients with metastatic cancers. However, advances in our understanding of BrM have been hampered by the constrained sample size and resolution of BrM profiling studies. Here, we perform integrative single-cell RNA sequencing analysis on 108 BrM samples and 111 primary tumor (PTs) samples to investigate the characteristics and remodeling of cell states and composition across cancer lineages and subsets. Recurring and enriched features of malignant cells are increased chromosomal instability, marked proliferative and angiogenic hallmarks, and adoption of a neural-like BrM-associated metaprogram. Immunosuppressive myeloid and stromal subsets dominate the BrM tumor microenvironment, which are associated with poor prognosis and resistance to immunotherapy. Furthermore, five distinct BrM ecotypes are identified, correlating with specific histopathological patterns and clinical characteristics. This work defines hallmarks of BrM biology across cancer types and suggests that shared dependencies may exist, which may be exploited clinically.},
  number={7},
  journal={Cancer Cell},
  author={Xing, Xudong and Zhong, Jian and Biermann, Jana and Duan, Hao and Zhang, Xinyu and Shi, Yu and Gao, Yixin and He, Kejun and Zhai, Duanyang and Luo, Feng and Lai, Yanxing and Xiao, Feizhe and Wang, Wenying and Wang, Mengru and Xu, Jianguo and Liu, Hao and Tang, Jiaze and Chu, Liangzhao and Chen, Tunan and D’Souza, Edridge K. and Caprio, Lindsay and Ebel, Leon and Biswas, Devanik and Cottarelli, Azzurra and Mou, Yonggao and Izar, Benjamin and Zhang, Nu and Bai, Fan},
  year={2025},
  month=july,
  pages={1242-1260.e9}
}

